{
  "name": "syncnesto",
  "private": true,
  "workspaces": [
    "backend",
    "src",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:backend dev:frontend",
    "dev:backend": "npm --prefix backend run start:dev",
    "dev:frontend": "npm --prefix src run dev"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}